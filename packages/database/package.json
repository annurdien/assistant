{
  "name": "@assistant/database",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Prisma DB client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "clean": "rm -rf dist *.tsbuildinfo src/generated"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3",
    "tsx": "^4.19.2",
    "dotenv": "^16.4.7"
  }
}
