{
  "name": "@assistant/sdk",
  "version": "0.0.1",
  "private": false,
  "description": "Public SDK for consumers of this platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@assistant/core": "workspace:*",
    "@assistant/database": "workspace:*",
    "@assistant/services": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  }
}
