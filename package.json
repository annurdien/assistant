{
  "name": "assistant-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "pnpm monorepo workspace",
  "scripts": {
    "start": "concurrently -c \"blue,magenta,cyan\" -n \"api,wa,dash\" \"pnpm run start:api\" \"pnpm run start:wa\" \"pnpm run start:dash\"",
    "start:prod": "concurrently -c \"blue,magenta,cyan\" -n \"api,wa,dash\" \"pnpm run start:prod:api\" \"pnpm run start:prod:wa\" \"pnpm run start:prod:dash\"",
    "start:api": "pnpm --filter @assistant/api-server run start:dev",
    "start:wa": "pnpm --filter @assistant/whatsapp-service run start:dev",
    "start:dash": "pnpm --filter @assistant/dashboard run dev",
    "start:prod:api": "pnpm --filter @assistant/api-server run start",
    "start:prod:wa": "pnpm --filter @assistant/whatsapp-service run start",
    "start:prod:dash": "pnpm --filter @assistant/dashboard run preview --host 0.0.0.0 --port 5173",
    "build": "pnpm --filter './packages/**' run build && pnpm --filter './apps/**' run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.8",
      "@hono/node-server": "^1.19.11",
      "lodash": "^4.17.23",
      "dompurify": "^3.3.3"
    }
  },
  "packageManager": "pnpm@9.12.0"
}
