{
  "name": "@assistant/worker",
  "version": "0.0.1",
  "private": true,
  "description": "Background job and queue worker",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@assistant/core": "workspace:*",
    "@assistant/services": "workspace:*",
    "@assistant/sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
