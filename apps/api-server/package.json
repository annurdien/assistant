{
  "name": "@assistant/api-server",
  "version": "0.0.1",
  "private": true,
  "description": "REST/GraphQL API server",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "start:dev": "tsx --env-file=.env src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@assistant/core": "workspace:*",
    "@assistant/services": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "fastify": "^5.8.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  }
}
