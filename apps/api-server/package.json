{
  "name": "@assistant/api-server",
  "version": "0.0.1",
  "private": true,
  "description": "REST/GraphQL API server",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "start:dev": "tsx --env-file=../../.env src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@assistant/core": "workspace:*",
    "@assistant/database": "workspace:*",
    "@assistant/services": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.2",
    "node-cron": "^4.2.1",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-schedule": "^2.1.8",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3"
  }
}
