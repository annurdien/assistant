# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=assistant
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ─── API Server ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_very_long_random_secret

# Allowed origin for the dashboard (e.g., https://yourdomain.com)
CORS_ORIGIN=http://localhost:5173

# ─── Admin Account ────────────────────────────────────────────
# Required on first boot to seed the admin user. MUST be set — startup will refuse if missing.
ADMIN_PASSWORD=change_me_secure_admin_password

# ─── Rate Limiting ────────────────────────────────────────────
MAX_DAILY_COMMANDS=50

# ─── AI / Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─── WhatsApp Service ─────────────────────────────────────────
API_EXECUTE_URL=http://localhost:3000/execute

# ─── Dashboard ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
